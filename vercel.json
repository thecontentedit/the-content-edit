{
  "version": 2,
  "rewrites": [
    { "source": "/embed/:widgetId", "destination": "/public/embed.html" },
    { "source": "/widget/:widgetId", "destination": "/public/embed.html" }
  ],
  "headers": [
    {
      "source": "/embed/:widgetId",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 10 },
    "api/**/*.js": { "maxDuration": 10 }
  }
}
