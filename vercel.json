{
  "rewrites": [
    { "source": "/setup", "destination": "/setup.html" },
    { "source": "/embed/:widgetId", "destination": "/embed.html" },
    { "source": "/widget/:widgetId", "destination": "/embed.html" }
  ],
  "headers": [
    {
      "source": "/embed/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
